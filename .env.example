# ── DevX Nexus AI Concierge — environment template ──
# Copy to .env and fill in real values. Never commit your real .env.

# Primary LLM — Groq Llama 3.1 (free): https://console.groq.com  (keys start with gsk_)
GROQ_API_KEY=gsk_your-real-groq-key-here

# Optional fallback LLM — OpenAI (used only if GROQ key is absent)
OPENAI_API_KEY=

# Admin dashboard PIN
ADMIN_PIN=1234
